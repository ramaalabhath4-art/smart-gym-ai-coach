# ============================================================
# Smart Gym AI Coach — Frontend Environment Variables
# Copy this to .env and fill in real values
# NEVER commit .env to git
# ============================================================

# Database (PlanetScale)
# Format: mysql://USERNAME:PASSWORD@HOST/DATABASE?ssl={"rejectUnauthorized":true}
DATABASE_URL=mysql://your_user:your_password@aws.connect.psdb.cloud/smart_gym_ai?ssl={"rejectUnauthorized":true}

# Auth
JWT_SECRET=replace_with_a_random_32_character_secret_string

# Python AI Backend URL
PYTHON_API_URL=https://smart-gym-python-api.onrender.com

# n8n (Railway deployment)
# Server-side: used in server/routers.ts
N8N_BASE_URL=https://your-n8n.railway.app
# Client-side: used in Settings.tsx (must be prefixed VITE_)
VITE_N8N_BASE_URL=https://your-n8n.railway.app

# App
NODE_ENV=production
VITE_APP_ID=coach_ai
